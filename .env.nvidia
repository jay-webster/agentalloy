# Platform preset: NVIDIA GPU (CUDA acceleration)
#
# Hardware: Any NVIDIA GPU with CUDA support (GTX 1060+ / RTX series).
#   Ollama or vLLM handles both embedding and generation on GPU.
#
# VRAM minimum: 2 GB (nomic-embed-text-v1.5 ~640 MB + qwen3.5:0.8b ~1.0 GB)
#   8+ GB VRAM for larger authoring models (qwen3.5:9b, :27b).
#   For vLLM with continuous batching, 8+ GB VRAM.
#
# Setup (Ollama — simplest):
#   1. Install Ollama — https://ollama.com
#      Ollama auto-detects CUDA if NVIDIA drivers + CUDA toolkit installed.
#   2. ollama pull nomic-embed-text-v1.5    # (runtime embed now via llama-server :47951)
#   3. ollama pull qwen3.5:0.8b           # or :4b / :9b if VRAM allows
#   4. ollama serve                        # default :11434
#   5. cp .env.nvidia .env
#
# Setup (vLLM — higher throughput):
#   1. pip install vllm
#   2. vllm serve nomic-ai/nomic-embed-text-v1.5 --port 47951
#      (or run embedding + generation on separate ports)
#   3. Adjust URLs below to match your vLLM port(s).
#
# Notes:
#   - nomic-embed-text-v1.5 produces 768-dim vectors, matching the
#     runtime's EMBEDDING_DIM (see storage/vector_store.py). ~640 MB
#     on disk.
#   - vLLM is better for concurrent requests (continuous batching).
#     Ollama is simpler for single-user local dev.
#   - For multi-GPU setups, vLLM supports tensor parallelism natively.

# Storage
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# Runtime embeddings — llama-server with CUDA (default embed port 47951)
#   Serve nomic with: --embeddings --pooling mean --ctx-size 2048 --ubatch-size 2048
#   nomic requires "search_query: " / "search_document: " prefixes.
RUNTIME_EMBED_BASE_URL=http://localhost:47951
RUNTIME_EMBEDDING_MODEL=nomic-embed-text-v1.5.Q8_0.gguf

# Signal intent reranker — llama-server (Qwen3-Reranker) on port 47952.
#   Powers reranker-primary phase-transition intent detection. If unset or
#   unreachable, the signal layer degrades to the cosine floor (the embedder
#   above), then to deterministic keyword matching.
SIGNAL_INTENT_RERANK_URL=http://localhost:47952
SIGNAL_INTENT_RERANK_MODEL=Qwen3-Reranker-0.6B-Q8_0.gguf

# Authoring pipeline — Ollama with CUDA
LM_STUDIO_BASE_URL=http://localhost:11434
AUTHORING_EMBED_BASE_URL=http://localhost:11434
AUTHORING_MODEL=qwen3.5:0.8b
CRITIC_MODEL=qwen3.5:0.8b
AUTHORING_EMBEDDING_MODEL=nomic-embed-text-v1.5

# Dedup / QA
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
