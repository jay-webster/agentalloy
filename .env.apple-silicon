# Platform preset: Apple Silicon (M1/M2/M3/M4 — Metal acceleration)
#
# Hardware: Any Apple Silicon Mac.
#   llama-server (llama.cpp) uses Metal (GPU) for both embedding and reranking.
#   Alternatively, use LM Studio with the llama.cpp Metal backend.
#
# RAM minimum: 8 GB unified memory (embed + reranker)
#   16 GB recommended for authoring with larger models (14B+).
#
# Setup:
#   1. Install llama.cpp (provides `llama-server`) — a native ARM64 Metal build.
#   2. Start the embed server on :47951:
#        llama-server --embeddings --pooling mean --ctx-size 2048 \
#          --ubatch-size 2048 --port 47951 -m nomic-embed-text-v1.5.Q8_0.gguf
#   3. Start the reranker server on :47952:
#        llama-server --port 47952 -m Qwen3-Reranker-0.6B-Q8_0.gguf
#   4. cp .env.apple-silicon .env
#
# Notes:
#   - llama-server on Apple Silicon uses Metal automatically. No extra config.
#   - nomic-embed-text-v1.5 produces 768-dim vectors, matching the
#     runtime's EMBEDDING_DIM (see storage/vector_store.py). ~640 MB
#     on disk.
#   - For higher throughput, use LM Studio with its Metal backend
#     and change the URLs to http://localhost:1234.
#   - MLX-based servers (e.g. mlx-lm) also expose OpenAI-compatible
#     endpoints and work without code changes — just update the URLs.

# Storage
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# Runtime embeddings — llama-server with Metal (default embed port 47951)
#   Serve nomic with: --embeddings --pooling mean --ctx-size 2048 --ubatch-size 2048
#   nomic requires "search_query: " / "search_document: " prefixes.
RUNTIME_EMBED_BASE_URL=http://localhost:47951
RUNTIME_EMBEDDING_MODEL=nomic-embed-text-v1.5.Q8_0.gguf

# Signal intent reranker — llama-server (Qwen3-Reranker) on port 47952.
#   Powers reranker-primary phase-transition intent detection. If unset or
#   unreachable, the signal layer degrades to the cosine floor (the embedder
#   above), then to deterministic keyword matching.
SIGNAL_INTENT_RERANK_URL=http://localhost:47952
SIGNAL_INTENT_RERANK_MODEL=Qwen3-Reranker-0.6B-Q8_0.gguf

# Stage B — LM-assist fragment reranker (composition-quality lift). Reuses the
#   Qwen3-Reranker above to score the ~12 candidate fragments per compose and
#   drop the off-task ones. ON for GPU targets: Metal offload finishes the 12
#   scores inside the budget. (On CPU they serialize past the budget, time out,
#   and fail open — so .env.cpu and the container leave this off.)
LM_ASSIST=arbitrate
LM_ASSIST_TIMEOUT_MS=1500

# Authoring pipeline — OpenAI-compatible endpoint (e.g. LM Studio / llama-server) with Metal
LM_STUDIO_BASE_URL=http://localhost:11434
AUTHORING_EMBED_BASE_URL=http://localhost:11434
AUTHORING_MODEL=qwen3.5:0.8b
CRITIC_MODEL=qwen3.5:0.8b
AUTHORING_EMBEDDING_MODEL=nomic-embed-text-v1.5

# Dedup / QA
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
