# SDD workflow internal artifacts (specs, designs, test plans, reviews).
# The lifecycle writes the spec phase to docs/spec/<slug> (singular); the old
# docs/specs/ pattern never matched it, so generated specs leaked as untracked-
# but-committable files. Keep the singular form.
docs/spec/
docs/design/
docs/tests/
docs/qa/
docs/ship/

# Per-session scratch handoff notes (regenerable; never part of the repo).
HANDOFF.md
docs/reviews/
docs/plan/
docs/audit/
docs/archive/
/specs/
/plans/
/design/

# Serena MCP tooling state
.serena/

# v5 two-engine storage — never commit generated corpus/engine files
*.duck
*.lance/
fragments.lance/
agentalloy.duck
telemetry.duck
*.gguf
models/

# Test-run residue (podman storage + tmp scripts from test suite)
containers-user-1000/
tmp*.sh
tmp*/
# Un-stubbed Path mocks in tests can materialize a MagicMock/ dir
MagicMock/

# Prebuilt corpus staging for container builds — CI populates this;
# only the .keep marker is tracked.
corpus-seed/*
!corpus-seed/.keep
