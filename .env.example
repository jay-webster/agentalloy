# agentalloy — environment template
#
# This file documents every knob. For a real install, don't hand-edit — render
# the platform preset:  agentalloy write-env --preset <cpu|nvidia|radeon|apple-silicon>
# The presets in src/agentalloy/install/presets/*.yaml are the single source of
# truth; this template is the annotated reference for the keys they set.
#
#   cpu           — universal CPU+RAM (any machine, no accelerator)
#   nvidia        — NVIDIA discrete GPU (CUDA)
#   radeon        — AMD Radeon dGPU or APU iGPU (Vulkan/ROCm), incl. Strix Point
#   apple-silicon — Apple Silicon (Metal)

# --- Storage (same for all platforms) ---
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# --- Upstream LLM (what the proxy forwards chat completions to) ---
# Global fallback for the OpenAI-compatible surface (bare env names, no prefix).
# A per-repo upstream captured by `agentalloy add <harness>` (.agentalloy/upstream)
# overrides these for that repo, so most installs leave them blank and adopt per
# repo instead. Set them here only to define a machine-wide default.
# UPSTREAM_URL=https://api.openai.com/v1
# UPSTREAM_MODEL=gpt-4o
# UPSTREAM_API_KEY=
# Native Anthropic passthrough (/proj/<token>/v1/messages) target. The caller's
# OWN credential is forwarded verbatim and none is stored; point this at another
# proxy to chain (Claude Code -> AgentAlloy -> ... -> Anthropic).
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# --- Runtime embeddings (retrieve / compose) ---
# Point at whichever OpenAI-compatible embedding server you run (llama-server
# is the standard runtime; Ollama is not used). Default embed port
# is 47951. Serve nomic with: --embeddings --pooling mean --ctx-size 2048
# --ubatch-size 2048.
# All embedding models must produce 768-dim vectors (EMBEDDING_DIM in
# storage/vector_store.py). nomic requires literal "search_query: " /
# "search_document: " prefixes on queries / documents.
RUNTIME_EMBED_BASE_URL=http://localhost:47951
RUNTIME_EMBEDDING_MODEL=nomic-embed-text-v1.5.Q8_0.gguf

# --- Cross-encoder rerank stage (optional, off by default) ---
# Reorders the top candidate skills before selection. Failures always degrade
# silently to the un-reranked order. Modes:
#   off  — disabled (today's behavior, the default)
#   onnx — in-process tiny cross-encoder; needs the [rerank] extra +
#          RUNTIME_RERANK_ONNX_DIR (a dir with model.onnx + tokenizer.json)
#   http — POST to a llama-server /v1/rerank sidecar; needs BASE_URL + MODEL
RUNTIME_RERANK_MODE=off
RUNTIME_RERANK_ONNX_DIR=
RUNTIME_RERANK_BASE_URL=
RUNTIME_RERANK_MODEL=
RUNTIME_RERANK_TIMEOUT_MS=150
RUNTIME_RERANK_MAX_PAIRS=32

# --- Signal intent reranker (phase-transition trigger) ---
# Reranker-primary phase transitions: the signal layer scores each prompt's
# intent (completion / approval) to decide whether to advance the SDD phase, so
# natural language ("looks right, now the design") works without rigid keywords.
# Served by a Qwen3-Reranker llama-server on 47952. If unreachable, degrades to
# the cosine floor (the embedder), then to deterministic keyword matching. Set
# SIGNAL_INTENT_BACKEND=cosine to force the embedder-based floor (no reranker).
SIGNAL_INTENT_BACKEND=reranker
SIGNAL_INTENT_RERANK_URL=http://localhost:47952
SIGNAL_INTENT_RERANK_MODEL=Qwen3-Reranker-0.6B-Q8_0.gguf

# Stage B — LM-assist fragment reranker (composition-quality lift). Off by
# default. Scores the ~8 candidate fragments per compose, filters off-task ones,
# then routes the survivors through diversity selection. Turn ON (arbitrate) only
# where the reranker runs on GPU — scoring fragments on a CPU reranker exceeds the
# budget, times out, and fails open. The rerank launcher picks --parallel 2/-c
# 4096 for GPU and --parallel 1/-c 2048 for CPU (opposite optima: more slots
# help GPU; fewer slots help CPU because of OpenMP thread contention).
# v5.0.0 default: OFF. Fragment re-rank showed no lift on the eval set
# (2026-06-12) and adds ~500ms/compose; v4.0.2 had enabled it for n=2 / real-life
# skill-ranking issues, but it ships off for now pending a cleaner fix. The
# intent reranker (SIGNAL_INTENT_BACKEND, above) stays ON — that's the measured
# win. Set to "arbitrate" to re-enable fragment re-rank.
LM_ASSIST=off
# 2000ms budget across all presets — leaves headroom for cold-start (~1.2s GPU
# prompt-eval) plus margin for slower-than-measured CPUs. Warm steady-state:
# GPU K=8 ~485ms, CPU K=8 ~1170ms (Xeon W-2225, Jun 2026).
# LM_ASSIST_TIMEOUT_MS=2000
# Candidate fan-out per composition. Default 8 == the reranker --parallel slot
# count (start-rerank-server). This single knob also sizes the scorer thread pool
# and is shared by BOTH scorer singletons (compose Stage B + signal intent), so the
# two consumers can never oversubscribe the reranker's slots.
# LM_ASSIST_MAX_CANDIDATES=8
# Per-fragment char cap applied before scoring (~600 tok). A prefill bound that
# keeps fat-corpus outliers inside the budget; sits above the authoring budget so
# well-sliced fragments never truncate.
# LM_ASSIST_DOC_CAP_CHARS=2400
# Relevance floor below which Stage B drops a fragment. Ships TRULY INERT and
# gated-off at 0.0: the keep test is `score >= threshold` and reranker
# yes-probabilities are in [0, 1], so every scored fragment survives — even ones
# the reranker scores exactly 0.0 (which happens for tasks with no relevant
# corpus coverage). The win is the restored diversity selection on the HIT path,
# not the filter. The real prod value is a DEFERRED decision gate pending a
# P(yes) distribution measurement — measure THEN set; no preset carries it yet.
# Override here only for measurement runs. (0.05 would NOT be inert; would empty
# the all-0.0 case. Live-test correction in v4.0.0.)
# LM_ASSIST_KEEP_THRESHOLD=0.0

# --- Retrieval engine: per-phase budgets & selection tuning (all optional) ---
# Per-phase k (candidate count) and max_tokens hint overrides. <PHASE> is the
# phase name upper-cased with '-' -> '_' (e.g. AGENTALLOY_K_SDD_FAST). Unset =>
# the built-in phase defaults; k and max_tokens move in lockstep (raising k
# without max_tokens starves the budget). Phases: build, ship, qa, spec, design,
# intake, sdd-fast.
# AGENTALLOY_K_BUILD=4
# AGENTALLOY_MAX_TOKENS_BUILD=4096
# Tier-2 (second-pass) candidate count. Unset => phase default; clamped to [1,50].
# AGENTALLOY_TIER2_K=
# Deepen-gate band [0,1]: a spare selection slot deepens the top skill unless a
# sibling's lead fragment scores within this fraction of the top skill's lead.
# Ships inert at 0.0 (legacy breadth-first selection); ~0.85 is the post-K-sweep
# recommendation.
# AGENTALLOY_DEEPEN_BAND=0.0
# contract_tags soft domain filter. On by default (empty-fallback safe); set to
# off to disable narrowing the candidate pool to contract-tagged fragments.
# AGENTALLOY_CONTRACT_TAG_FILTER=on
# Phase/category pool gate. Ships OFF (phase-agnostic, today's behavior). The
# gate is a mechanism for excluding `category: benchmark` packs from prod
# retrieval; reserved for ACTUAL benchmark-only packs (synthetic fixtures, eval
# corpora). Do NOT use it to hide real product skills — fix retrieval noise
# structurally (Stage B + tag-focus + atomicity) instead.
# AGENTALLOY_PHASE_GATE=off

# --- SDD workflow gates (optional) ---
# Human-in-the-loop approval on the sdd-fast lane. Default OFF — sdd-fast keeps
# `phase set qa` as the forward verb without an explicit approval marker. Set to
# 'true' / '1' / 'on' to require `agentalloy approve sdd-fast` before sdd-fast→qa.
# Spec→design and design→build on the FULL lane always require approval (not
# gated by this flag); `--force` does NOT bypass approval — only the artifact-
# completeness gates carve out for force. See docs/operator.md.
# SDD_FAST_REQUIRE_APPROVAL=off

# --- Context modules ---
# AgentAlloy serves independent context modules from one process. Routers for
# a disabled module are never registered (endpoints 404); /health reports
# per-module status. compose = the instruction injector (skill compose /
# retrieve / proxy — the original surface, on by default). code_index = the
# codebase indexer (/code/*, off by default; needs the [code-index] extra).
# COMPOSE_ENABLED=1
# CODE_INDEX_ENABLED=0
# Per-repo index data (graph + vectors per repo slug). Rebuilt, never migrated.
# CODE_INDEX_DATA_DIR=~/.local/share/agentalloy/code_index
# Watchdog-driven incremental reindex of wired repos.
# CODE_INDEX_WATCH=0

# --- Authoring pipeline (skill generation + QA — optional) ---
# Only needed if you author new skills. Skippable for runtime-only use.
LM_STUDIO_BASE_URL=http://localhost:1234
AUTHORING_EMBED_BASE_URL=http://localhost:1234
AUTHORING_MODEL=qwen/qwen3.6-35b-a3b
CRITIC_MODEL=qwen/qwen3.6-35b-a3b
# Must also be 768-dim — use nomic-embed-text-v1.5 to match the runtime.
AUTHORING_EMBEDDING_MODEL=nomic-embed-text-v1.5

# --- Dedup / QA tuning ---
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3

# --- Release notifications (optional) ---
# On by default: the service checks GitHub for a newer release at most once a
# day (the only outbound call it makes), caches the result, and surfaces a
# nudge on the status line, `agentalloy status`, and server-start. The check is
# fail-silent — with no egress (air-gapped / container) it simply shows nothing.
# Set to 0 (or off/false/no) to disable the check entirely.
AGENTALLOY_RELEASE_CHECK=1
