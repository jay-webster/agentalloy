# Platform preset: Universal CPU+RAM (no accelerator required)
#
# Hardware: Any x86_64 or ARM64 machine.
#   No GPU, NPU, or specialized accelerator needed.
#   llama-server (llama.cpp) handles embedding and reranking on CPU.
#
# RAM minimum: 8 GB (nomic-embed-text-v1.5 ~640 MB + Qwen3-Reranker ~0.7 GB)
#   For authoring with a larger model, 16+ GB recommended.
#
# Setup:
#   1. Install llama.cpp (provides `llama-server`) — a CPU build.
#   2. Start the embed server on :47951:
#        llama-server --embeddings --pooling mean --ctx-size 2048 \
#          --ubatch-size 2048 --port 47951 -m nomic-embed-text-v1.5.Q8_0.gguf
#   3. Start the reranker server on :47952:
#        llama-server --port 47952 -m Qwen3-Reranker-0.6B-Q8_0.gguf
#   4. cp .env.cpu .env
#
# Notes:
#   - nomic-embed-text-v1.5 produces 768-dim vectors, matching the
#     runtime's EMBEDDING_DIM (see storage/vector_store.py). ~640 MB
#     on disk.
#   - qwen3.5:0.8b is the smallest viable generation model for
#     authoring (~1.0 GB). For runtime-only use (no authoring), you
#     only need the embedding model.
#   - Inference speed will be slower than GPU variants. Acceptable
#     for the runtime path (embed + retrieve is <200ms even on CPU).
#     Authoring pipeline will be noticeably slower.

# Storage
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# Runtime embeddings — llama-server on CPU (default embed port 47951)
#   Serve nomic with: --embeddings --pooling mean --ctx-size 2048 --ubatch-size 2048
#   nomic requires "search_query: " / "search_document: " prefixes.
RUNTIME_EMBED_BASE_URL=http://localhost:47951
RUNTIME_EMBEDDING_MODEL=nomic-embed-text-v1.5.Q8_0.gguf

# Signal intent reranker — llama-server (Qwen3-Reranker) on port 47952.
#   Powers reranker-primary phase-transition intent detection. If unset or
#   unreachable, the signal layer degrades to the cosine floor (the embedder
#   above), then to deterministic keyword matching.
SIGNAL_INTENT_RERANK_URL=http://localhost:47952
SIGNAL_INTENT_RERANK_MODEL=Qwen3-Reranker-0.6B-Q8_0.gguf

# Stage B — LM-assist fragment reranker. OFF on CPU: scoring the ~12 candidate
#   fragments serializes past the latency budget on a CPU reranker, times out,
#   and fails open to deterministic selection (no harm, just wasted time). GPU
#   targets (.env.nvidia / .env.apple-silicon) turn it on. Note: the signal
#   intent reranker above is a single comparison and stays fine on CPU.
LM_ASSIST=off

# Authoring pipeline — OpenAI-compatible endpoint (e.g. LM Studio / llama-server) on CPU (optional, skip for runtime-only)
LM_STUDIO_BASE_URL=http://localhost:11434
AUTHORING_EMBED_BASE_URL=http://localhost:11434
AUTHORING_MODEL=qwen3.5:0.8b
CRITIC_MODEL=qwen3.5:0.8b
AUTHORING_EMBEDDING_MODEL=nomic-embed-text-v1.5

# Dedup / QA
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
